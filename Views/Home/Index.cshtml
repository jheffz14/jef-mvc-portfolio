@model PortfolioViewModel

<!-- ══ HERO ═════════════════════════════════════════════════════════════════ -->
<section id="home" class="hero">
    <div class="hero-dots" aria-hidden="true">
        @for (int i = 0; i < 80; i++)
        {
            <div class="dot"></div>
        }
    </div>
    <div class="hero-content">
        <p class="hero-pre">Hello, World! 👋</p>
        <h1 class="hero-name">I'm <span class="accent">Jeff</span></h1>
        <h2 class="hero-role"><span class="typewriter">Backend Developer</span></h2>
        <p class="hero-sub">
            I develop backend systems and ASP.NET applications.
        </p>
        <div class="hero-btns">
            <a href="#projects" class="btn btn-primary">View My Work</a>
            <a href="#contact" class="btn btn-outline">Contact Me</a>
        </div>
        <div class="hero-stats">
            <div class="stat">
                <span class="stat-num">@Model.Projects.Count+</span>
                <span class="stat-lbl">Projects</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
                <span class="stat-num">@Model.Skills.Count+</span>
                <span class="stat-lbl">Skills</span>
            </div>  
        </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
        <div class="code-card">
            <div class="code-top">
                <span class="dot-r"></span>
                <span class="dot-y"></span>
                <span class="dot-g"></span>
                <span class="code-filename">HomeController.cs</span>
            </div>
<pre class="code-body">public class HomeController
    : Controller
{
  public IActionResult Index()
  {
    var vm = new Portfolio
    {
      Developer = "Jef",
      Available = true
    };
    return View(vm);
  }
}</pre>
        </div>
    </div>
</section>

<!-- ══ ABOUT ════════════════════════════════════════════════════════════════ -->
<section id="about" class="about section reveal">
   @*  <div class="section-label">About Me</div> *@
    <div class="about-inner">
        <div class="about-avatar">
            <div class="avatar-ring">
                <div class="avatar-initials">JEF</div>
            </div>
            <div class="avatar-badge">
                <span class="badge-dot"></span> Available for work
            </div>
        </div>
        <div class="about-text">
            <h2 class="section-title">Who am I?</h2>
            <p>
                I'm <strong>Jef</strong>, a passionate Backend Developer who loves turning ideas
                into interactive digital experiences. I focus on writing clean, maintainable
                code and building applications that feel great to use.
            </p>
            <p>
                Currently diving deep into <span class="accent">ASP.NET Core MVC</span>,
                learning <span class="accent">Git workflows</span>, and building
                projects that push my skills every single day.
            </p>
            <div class="about-tags">
                <span class="tag">Problem Solver</span>
                <span class="tag">Fast Learner</span>
                <span class="tag">Open Source Fan</span>
            </div>
            <a href="#contact" class="btn btn-primary" style="margin-top:1.5rem;display:inline-block">
                Let's Connect →
            </a>
        </div>
    </div>
</section>

<!-- ══ SKILLS ═══════════════════════════════════════════════════════════════ -->
<section id="skills" class="skills section reveal">
   @*  <div class="section-label">Skills</div> *@
    <h2 class="section-title">My Toolkit</h2>

    <!-- Filter Buttons -->
    <div class="filter-tabs">
        <button class="filter-btn active" onclick="filterSkills('All', this)">All</button>
        @foreach (var cat in Model.Skills.Select(s => s.Category).Distinct())
        {
            <button class="filter-btn" onclick="filterSkills('@cat', this)">@cat</button>
        }
    </div>

    <!-- Skills Grid -->
    <div class="skills-grid" id="skillsGrid">
        @foreach (var skill in Model.Skills)
        {
            <div class="skill-item" data-category="@skill.Category">
                <div class="skill-top">
                    <span class="skill-name">@skill.Name</span>
                </div>
            </div>
        }
    </div>
</section>

<!-- ══ PROJECTS ══════════════════════════════════════════════════════════════ -->
    <section id="projects" class="projects section reveal">
        <h2 class="section-title">What I've Built</h2>

        <div class="projects-carousel-wrapper">
            <div class="projects-grid" id="projectsGrid">
                @foreach (var project in Model.Projects)
                {
                    <div class="project-card reveal" style="--card-accent: @project.AccentColor">
                        <div class="card-top-bar" style="background: @project.AccentColor"></div>
                        <div class="card-body">
                            <h3 class="card-title">@project.Title</h3>
                            <p class="card-desc">@project.Description</p>
                            <div class="card-tags">
                                @foreach (var tag in project.Tags)
                                {
                                    <span class="card-tag" style="color:@project.AccentColor; border-color:@project.AccentColor">
                                        @tag
                                    </span>
                                }
                            </div>
                            @if (project.Id == 1)
                            {
                                <button id="openPOSBtn"
                                        class="card-link"
                                        style="background:none; border:none; padding:0; cursor:pointer; font-family:inherit;">
                                    View Project <span>→</span>
                                </button>
                            }
                            else
                            {
                                <a href="@project.Link" class="card-link">View Project <span>→</span></a>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Carousel controls — hidden on desktop, visible on mobile -->
            <div class="carousel-controls" id="carouselControls">
                <button class="carousel-btn carousel-prev" id="carouselPrev" aria-label="Previous project">&#8592;</button>
                <div class="carousel-dots" id="carouselDots"></div>
                <button class="carousel-btn carousel-next" id="carouselNext" aria-label="Next project">&#8594;</button>
            </div>
        </div>
    </section>

<!-- ══ CONTACT ═══════════════════════════════════════════════════════════════ -->
<section id="contact" class="contact section reveal">
    @* <div class="section-label">Contact</div> *@
    <h2 class="section-title">Get In Touch</h2>
    <p class="contact-sub">Have a project in mind or just want to say hi? My inbox is always open.</p>

    <div class="contact-inner">
        <!-- Info -->
        <div class="contact-info">
            <div class="info-item">
                <span class="info-icon">📍</span>
                <div ><strong style="margin-left:10px;">Location</strong><br/>
                        <div style="margin-left:10px;">Philippines</div>
                  </div>
            </div>
            <div class="info-item">
                <span class="info-icon">💼</span>
                <div><strong>Status</strong><br />Open to opportunities</div>
            </div>
            <div class="info-item">
                <span class="info-icon">🚀</span>
                    <div>
                        <strong>GitHub</strong><br />
                        <a href="https://github.com/jheffz14" style="color:white;">https://github.com/jheffz14</a></div>

                    
            </div>
        </div>

        <!-- Contact Form — posts to HomeController.SendMessage -->
            <form asp-action="SendMessage" asp-controller="Home" method="post" class="contact-form" id="contactForm">
                @Html.AntiForgeryToken()

             @*    @if (Model.MessageSent)
                {
                    <div class="form-success">✅ Message sent! I'll get back to you soon.</div>
                } *@

                <div class="form-row">
                    <div>
                        <input name="Name" placeholder="Your Name"
                               value="@Model.ContactForm.Name" />
                    </div>
                    <div>
                        <input name="Email" type="email" placeholder="Your Email"
                               value="@Model.ContactForm.Email" />
                    </div>
                </div>

                <textarea name="Message" rows="5"
                          placeholder="Your Message...">@Model.ContactForm.Message</textarea>

                <button type="submit" class="btn btn-primary">Send Message ✉️</button>
            </form>
    </div>
</section>

    @{
        var posProject = Model.Projects.FirstOrDefault(p => p.Id == 1);
    }

    @if (posProject != null && posProject.Slides.Any())
    {
        <div id="posModal">

            <div class="pos-modal-box" style="max-width:1200px;">

                <!-- Close -->
                <button id="posCloseBtn" class="pos-close-btn">&#x2715;</button>

                <!-- Header -->
                <h2 class="pos-modal-title">@posProject.Title</h2>
                <p class="pos-modal-desc">@posProject.Description</p>

                <!-- Counter -->
                <div class="pos-counter">
                    <span id="posCounter">1</span> / @posProject.Slides.Count
                </div>

                <!-- Carousel -->
                <div class="pos-track-wrapper">
                    <div id="posSlides">
                        @for (int i = 0; i < posProject.Slides.Count; i++)
                        {
                            var slide = posProject.Slides[i];
                            <div class="pos-slide">

                                <!-- Icon + Title -->
                                <div class="pos-slide-header">
                                    <span class="pos-slide-icon">@slide.Icon</span>
                                    <h3 class="pos-slide-title">@slide.Title</h3>
                                </div>

                                <!-- Screenshot -->
                                @if (!string.IsNullOrEmpty(slide.ImagePath))
                                {
                                    <img src="@slide.ImagePath"
                                         alt="@slide.Title"
                                         class="pos-slide-img" />
                                }

                                <!-- Caption -->
                                <p class="pos-slide-caption">@slide.Caption</p>

                                <!-- Tags -->
                                <div class="pos-slide-tags">
                                    @foreach (var tag in slide.Tags)
                                    {
                                        <span class="pos-slide-tag">@tag</span>
                                    }
                                </div>

                            </div>
                        }
                    </div>
                </div>

                <!-- Navigation -->
                <div class="pos-nav">
                    <button id="posPrevBtn" class="pos-nav-btn">&#8592; Prev</button>

                    <div class="pos-dots">
                        @for (int i = 0; i < posProject.Slides.Count; i++)
                        {
                            <span class="pos-dot @(i == 0 ? "active" : "")"
                                  data-index="@i">
                            </span>
                        }
                    </div>

                    <button id="posNextBtn" class="pos-nav-btn">Next &#8594;</button>
                </div>

            </div>
        </div>
    }
   